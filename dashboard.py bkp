def get_database_stats():
    """Obtiene estadísticas de la base de datos"""
    if not os.path.exists(DB_PATH):
        return None
    
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    stats = {}
    
    try:
        # Total de ofertas
        cursor.execute("SELECT COUNT(*) FROM published_offers")
        stats['total_offers'] = cursor.fetchone()[0] or 0
        
        # Ofertas de hoy
        today = datetime.now().strftime('%Y-%m-%d')
        cursor.execute("SELECT COUNT(*) FROM published_offers WHERE DATE(published_at) = ?", (today,))
        stats['offers_today'] = cursor.fetchone()[0] or 0
        
        # Promedio de descuento
        cursor.execute("SELECT AVG(discount_percentage) FROM published_offers WHERE discount_percentage > 0")
        avg_discount = cursor.fetchone()[0] or 0
        stats['avg_discount'] = round(avg_discount, 1)
        
        # Precio promedio
        cursor.execute("SELECT AVG(final_price) FROM published_offers WHERE final_price > 0")
        avg_price = cursor.fetchone()[0] or 0
        stats['avg_price'] = round(avg_price, 2)
        
        # Ratio de afiliados
        cursor.execute("SELECT COUNT(*) FROM published_offers WHERE affiliate_url LIKE '%/sec/%'")
        with_affiliate = cursor.fetchone()[0] or 0
        stats['affiliate_ratio'] = round((with_affiliate / max(stats['total_offers'], 1)) * 100, 1)
        
        # Productos en caché
        try:
            cursor.execute("SELECT COUNT(*) FROM seen_products")
            stats['cache_count'] = cursor.fetchone()[0] or 0
        except:
            stats['cache_count'] = 0
        
        # Cálculos adicionales
        if stats['offers_today'] > 0:
            hours_passed = datetime.now().hour or 1
            stats['hourly_rate'] = round(stats['offers_today'] / hours_passed, 1)
        else:
            stats['hourly_rate'] = 0
        
        # Uptime simulado (horas desde medianoche)
        stats['uptime'] = datetime.now().hour
        
        # Tasa de éxito
        stats['success_rate'] = 98.5  # Puedes calcularlo real
        
        # Tamaño del caché
        if os.path.exists(DB_PATH):
            stats['cache_size'] = round(os.path.getsize(DB_PATH) / (1024*1024), 1)
        else:
            stats['cache_size'] = 0
        
    except Exception as e:
        print(f"Error obteniendo stats: {e}")
    finally:
        conn.close()
    
    return stats

def get_top_discounts(limit=10):
    """Obtiene las mejores ofertas por descuento"""
    if not os.path.exists(DB_PATH):
        return []
    
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    offers = []
    try:
        cursor.execute("""
            SELECT title, discount_percentage, final_price, published_at, 
                   affiliate_url, promo_tag
            FROM published_offers 
            WHERE discount_percentage > 0
            ORDER BY discount_percentage DESC 
            LIMIT ?
        """, (limit,))
        
        for row in cursor.fetchall():
            offers.append({
                'title': row[0] or "Sin título",
                'discount_pct': round(row[1] or 0),
                'price_final': row[2] or 0,
                'published_at': row[3] or "",
                'affiliate_url': row[4] or "",
                'promo_tag': row[5] or ""
            })
    except Exception as e:
        print(f"Error obteniendo top discounts: {e}")
    finally:
        conn.close()
    
    return offers

def get_recent_offers(limit=10):
    """Obtiene las ofertas más recientes"""
    if not os.path.exists(DB_PATH):
        return []
    
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    offers = []
    try:
        cursor.execute("""
            SELECT title, discount_percentage, final_price, published_at, affiliate_url
            FROM published_offers 
            ORDER BY published_at DESC 
            LIMIT ?
        """, (limit,))
        
        for row in cursor.fetchall():
            # Calcular "hace cuánto"
            try:
                pub_time = datetime.fromisoformat(row[3])
                diff = datetime.now() - pub_time
                if diff.days > 0:
                    time_ago = f"Hace {diff.days} días"
                elif diff.seconds > 3600:
                    time_ago = f"Hace {diff.seconds // 3600} horas"
                else:
                    time_ago = f"Hace {diff.seconds // 60} minutos"
            except:
                time_ago = "Reciente"
            
            offers.append({
                'title': row[0] or "Sin título",
                'discount_pct': round(row[1] or 0),
                'price_final': row[2] or 0,
                'published_at': row[3] or "",
                'time_ago': time_ago,
                'affiliate_url': row[4] or ""
            })
    except Exception as e:
        print(f"Error obteniendo ofertas recientes: {e}")
    finally:
        conn.close()
    
    return offers

def get_chart_data():
    """Obtiene datos para las gráficas"""
    if not os.path.exists(DB_PATH):
        return [], [], [], []
    
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    # Datos de últimos 7 días
    chart_labels = []
    chart_data = []
    
    for i in range(6, -1, -1):
        date = (datetime.now() - timedelta(days=i)).strftime('%Y-%m-%d')
        day_name = (datetime.now() - timedelta(days=i)).strftime('%a')
        
        chart_labels.append(day_name)
        
        try:
            cursor.execute(
                "SELECT COUNT(*) FROM published_offers WHERE DATE(published_at) = ?", 
                (date,)
            )
            count = cursor.fetchone()[0] or 0
            chart_data.append(count)
        except:
            chart_data.append(0)
    
    # Datos de categorías (simulado por ahora)
    category_labels = ['Electrónica', 'Hogar', 'Moda', 'Deportes', 'Juguetes', 'Otros']
    category_data = [25, 20, 15, 15, 10, 15]
    
    conn.close()
    
    return chart_labels, chart_data, category_labels, category_data

